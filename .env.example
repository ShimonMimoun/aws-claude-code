# --- Auth : choisir "entra" ou "cognito"
AUTH_PROVIDER=entra

# --- Azure Entra ID
ENTRA_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ENTRA_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ENTRA_CLIENT_SECRET=  # optionnel pour app publique
ENTRA_ISSUER=         # optionnel, dérivé de ENTRA_TENANT_ID si vide
ENTRA_AUDIENCE=       # optionnel, utilise ENTRA_CLIENT_ID si vide

# --- Cognito (si AUTH_PROVIDER=cognito)
COGNITO_REGION=eu-west-1
COGNITO_USER_POOL_ID=eu-west-1_xxxxx
COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_JWKS_URL=     # optionnel, dérivé du User Pool si vide
COGNITO_DOMAIN_PREFIX= # pour CLI login-cognito (Hosted UI), ex: myapp → myapp.auth.<region>.amazoncognito.com

# --- AWS : profil forgé (toutes les requêtes passent par ce rôle/clés)
AWS_REGION=eu-west-1
AWS_ROLE_ARN=arn:aws:iam::123456789012:role/MyProxyRole
AWS_ROLE_SESSION_NAME=bedrock-proxy-session

# Optionnel : en dev, credentials fixes au lieu d'AssumeRole
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Suivi d'utilisation : fichier JSONL (une ligne par appel)
# USAGE_LOG_PATH=usage.jsonl
